Token = your_discord_bot_token
ClientID = your_discord_application_id
WEATHER_API_KEY = your_openweathermap_api_key
MONGODB_URL = your_mongodb_url
GITHUB_TOKEN = your_github_token

# Bot presence (shown as the bot's status in Discord)
BOT_ACTIVITY_NAME = your bot's status text
BOT_ACTIVITY_TYPE = Watching

# Lavalink (leave HOST/PORT as-is for Docker; change host to 127.0.0.1 for local dev)
# Change LAVALINK_PASSWORD to your own value, it's shared with lavalink/application.yml via ${LAVALINK_PASSWORD}
LAVALINK_HOST = lavalink
LAVALINK_PORT = 2333
LAVALINK_PASSWORD = youshallnotpass

# Dashboard (optional — only needed if you run the dashboard service)
CLIENT_SECRET = your_discord_application_client_secret
SESSION_SECRET = a_long_random_string_at_least_32_chars
DASHBOARD_URL = http://localhost:3000

# Internal API (used by the dashboard to trigger giveaway end/reroll on the bot)
INTERNAL_API_PORT = 4000
INTERNAL_API_SECRET = a_long_random_secret_shared_with_the_dashboard